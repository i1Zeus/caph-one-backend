// Employee Exit - إنهاء خدمة الموظف
model EmployeeExit {
  id         String   @id @default(uuid())
  employeeId String   @unique
  employee   Employee @relation("EmployeeExit", fields: [employeeId], references: [id], onDelete: Cascade)

  exitType       ExitType
  exitDate       DateTime // تاريخ إنهاء الخدمة
  lastWorkingDay DateTime // آخر يوم عمل
  reason         String? // سبب الإنهاء
  detailedReason String? // سبب تفصيلي

  // Exit Interview - مقابلة الخروج
  exitInterviewDone Boolean   @default(false)
  exitInterviewDate DateTime?
  feedback          String? // ملاحظات الموظف
  rehireEligible    Boolean   @default(true) // هل يمكن إعادة توظيفه؟

