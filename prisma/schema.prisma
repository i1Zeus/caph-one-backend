generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  subdomain        String           @unique
  subscriptionTier SubscriptionTier @default(FREE)
  maxUsers         Int              @default(10)
  logo             String?
  maxWorkspaces    Int              @default(3) // SuperAdmin controls this per org
  isActive         Boolean          @default(true)
  isDeleted        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  // Relations
  users                    User[]
  workspaces               Workspace[]
  invitationTokens         InvitationToken[]
  clients                  Client[]
  accounts                 Account[]
  transactions             Transaction[]
  currencies               Currency[]
  departments              Department[]
  employees                Employee[]
  jobs                     Job[]
  products                 Product[]
  productCategories        ProductCategory[]
  unitCategories           UnitCategory[]
  units                    Unit[]
  warehouses               Warehouse[]
  warehouseTransactions    WarehouseTransaction[]
  salesInvoices            SalesInvoice[]
  purchaseInvoices         PurchaseInvoice[]
  purchaseReturnInvoices   PurchaseReturnInvoice[]
  salesReturnInvoices      SalesReturnInvoice[]
  invoiceAccountingConfigs InvoiceAccountingConfig[]
  accountingSettings       AccountingSettings[]
  posTerminals             POS[]
  invoiceTemplates         InvoiceTemplate[]
  sales                    Sale[]
  leads                    Lead[]
  leadStages               LeadStage[]
  actionHistories          ActionHistory[]
  loginEvents              LoginEvent[]

  @@map("organizations")
}

model InvitationToken {
  id             String       @id @default(uuid())
  token          String       @unique @default(uuid())
  email          String // Pre-set email for the invited user
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleIds        String[] // Role IDs to assign upon signup
  isUsed         Boolean      @default(false)
  usedAt         DateTime?
  usedByUserId   String? // The user who used this token
  expiresAt      DateTime // Token expiration
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([email])
  @@map("invitation_tokens")
}

model Workspace {
  id            String          @id @default(uuid())
  name          String
  description   String?
  slug          String          @unique // For URL-friendly workspace identification
  members       WorkspaceUser[] @relation("WorkspaceMembers")
  projects      Project[]       @relation("WorkspaceProjects")
  projectStages ProjectStage[]  @relation("WorkspaceProjectStages")
  leads         Lead[]          @relation("WorkspaceLeads")
  leadStages    LeadStage[]     @relation("WorkspaceLeadStages")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global Accounting Settings (single row table)
model AccountingSettings {
  id                       Int      @id @default(1)
  defaultCustomerAccountId Int?
  defaultCustomerAccount   Account? @relation("DefaultCustomerAccount", fields: [defaultCustomerAccountId], references: [id])
  defaultSupplierAccountId Int?
  defaultSupplierAccount   Account? @relation("DefaultSupplierAccount", fields: [defaultSupplierAccountId], references: [id])
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("accounting_settings")
}

model WorkspaceUser {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation("WorkspaceMembers", fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation("UserWorkspaces", fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  @@unique([workspaceId, userId])
}

model User {
  id                            String                  @id @default(uuid())
  name                          String
  password                      String
  email                         String                  @unique
  phone                         String                  @unique
  img                           String?
  workspaces                    WorkspaceUser[]         @relation("UserWorkspaces")
  assignedTasks                 Task[]                  @relation("TaskAssignees")
  createdTasks                  Task[]                  @relation("TaskCreator")
  projects                      Project[]               @relation("ProjectOwner")
  leads                         Lead[]                  @relation("LeadSalesMan")
  loginEvents                   LoginEvent[]
  actions                       ActionHistory[]         @relation("ActionUser")
  comments                      Comment[]               @relation("UserComments")
  taggedComments                Comment[]               @relation("CommentTaggedUsers")
  uploadedFiles                 File[]                  @relation("UserFiles")
  type                          PartnerType?
  projectsContributions         Project[]               @relation("ProjectContributors")
  leadActivities                LeadActivity[]          @relation("LeadActivities")
  employee                      Employee?               @relation("EmployeeUser")
  leaves                        Leave[]                 @relation("LeaveApprovals")
  salariesIPaid                 Salary[]                @relation("SalaryPaidBy")
  createdSalesInvoices          SalesInvoice[]          @relation("CreatedSalesInvoices")
  createdPurchaseInvoices       PurchaseInvoice[]       @relation("CreatedPurchaseInvoices")
  createdPurchaseReturnInvoices PurchaseReturnInvoice[] @relation("CreatedPurchaseReturnInvoices")
  createdSalesReturnInvoices    SalesReturnInvoice[]    @relation("CreatedSalesReturnInvoices")
  warehouseTransactions         WarehouseTransaction[]  @relation("WarehouseTransactions")
  uploadedEmployeeDocuments     EmployeeDocument[]      @relation("UploadedEmployeeDocuments")
  issuedDisciplinaryActions     DisciplinaryAction[]    @relation("IssuedDisciplinaryActions")
  reviewedEmployeeRequests      EmployeeRequest[]       @relation("ReviewedEmployeeRequests")
  processedEmployeeExits        EmployeeExit[]          @relation("ProcessedEmployeeExits")
  // Sales
  createdSales                  Sale[]                  @relation("SaleCreator")
  // Dynamic role assignment
  userRoles                     UserRole[]              @relation("UserRoles")

  isSuperAdmin   Boolean       @default(false)
  role           UserRoleType  @default(USER)
  firstName      String?
  lastName       String?
  lastLogin      DateTime?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean       @default(true)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  order          Int?          @default(0) // Order within the project stage or workspace
  workspaceId    String // Required: Every project must belong to a workspace
  workspace      Workspace     @relation("WorkspaceProjects", fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerId        String
  contributors   User[]        @relation("ProjectContributors")
  owner          User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks          Task[]        @relation("ProjectTasks")
  files          File[]        @relation("ProjectFiles")
  projectStageId String? // Optional: Projects can be unstaged
  projectStage   ProjectStage? @relation("ProjectStageProjects", fields: [projectStageId], references: [id], onDelete: SetNull)
  taskStages     TaskStage[]   @relation("ProjectTaskStages") // Project-specific task stages
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Task {
  id          String       @id @default(uuid())
  parentId    String?
  parent      Task?        @relation("TaskParent", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subtasks    Task[]       @relation("TaskParent")
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isDone      Boolean?     @default(false)
  order       Int?         @default(0) // Order within the task stage
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  assignees   User[]       @relation("TaskAssignees")
  comments    Comment[]    @relation("TaskComments")
  files       File[]       @relation("TaskFiles")
  projectId   String
  project     Project      @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  taskStageId String?
  taskStage   TaskStage?   @relation("TaskStageTasks", fields: [taskStageId], references: [id], onDelete: Cascade)
  timeStamps  TimeStamp[]  @relation("TaskTimeStamps")
  createdById String?
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TimeStamp {
  id          String   @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  description String?
  isDeleted   Boolean  @default(false)
  taskId      String
  task        Task     @relation("TaskTimeStamps", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  taskId      String
  task        Task     @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  authorId    String
  author      User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  taggedUsers User[]   @relation("CommentTaggedUsers")
  files       File[]   @relation("CommentFiles")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model File {
  id           String @id @default(uuid())
  originalName String // Original filename uploaded by user
  filename     String // Stored filename (usually UUID + extension)
  mimetype     String // MIME type of the file
  size         Int // File size in bytes
  url          String // Full URL to access the file
  key          String // Cloudflare R2 object key/path
  uploadedById String
  uploadedBy   User   @relation("UserFiles", fields: [uploadedById], references: [id], onDelete: Cascade)

  // Polymorphic relationships - a file can belong to one of these entities
  projectId String?
  project   Project? @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation("TaskFiles", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  commentId String?
  comment   Comment? @relation("CommentFiles", fields: [commentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectStage {
  id          String    @id @default(uuid())
  name        String
  order       Int?      @default(0)
  description String?
  color       String? // For UI visualization
  workspaceId String // Each stage belongs to a workspace
  workspace   Workspace @relation("WorkspaceProjectStages", fields: [workspaceId], references: [id], onDelete: Cascade)
  projects    Project[] @relation("ProjectStageProjects") // One project stage can have many projects
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, order])
}

model TaskStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  order       Int?
  color       String? // For UI visualization
  projectId   String // Project-specific task stages
  project     Project  @relation("ProjectTaskStages", fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]   @relation("TaskStageTasks") // One task stage can have many tasks
  isDefault   Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, order])
}

model ActionHistory {
  id          String   @id @default(uuid())
  actionType  String // CREATE, UPDATE, DELETE, ASSIGN, etc
  entityType  String // USER, PROJECT, TASK, STAGE, etc
  entityId    String // ID of the affected entity
  details     Json? // Extra info about the action
  link        String? // Link to the affected entity
  performedBy String?
  user        User?    @relation("ActionUser", fields: [performedBy], references: [id])
  createdAt   DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model LoginEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  device    String? // e.g. iPhone, Chrome on Windows
  location  String? // e.g. "Baghdad, Iraq"
  country   String? // e.g. "Iraq"
  city      String? // e.g. "Baghdad"
  state     String? // e.g. "Baghdad"
  zip       String? // e.g. "10000"
  latitude  Float? // e.g. 33.3152
  longitude Float? // e.g. 44.3661
  userAgent String? // Full user-agent string
  createdAt DateTime @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ===== ACCOUNTING =====
model Client {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  type      ClientType @default(SUPPLIER)

  // No direct balance tracking - الرصيد يُحسب من الحسابات المحاسبية

  // Account relationship - العلاقة مع الحساب
  accountId Int?
  account   Account? @relation("ClientAccount", fields: [accountId], references: [id])

  // Relationships
  transactions     Transaction[] // المعاملات المرتبطة بالعميل
  transactionLines TransactionLine[] // سطور المعاملات المرتبطة بالعميل
  salesInvoices    SalesInvoice[] // فواتير البيع (للعملاء)
  purchaseInvoices PurchaseInvoice[] // فواتير الشراء (للموردين)
  sales            Sale[] // Sales / Quotations

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("clients")
}

enum ClientType {
  CUSTOMER
  SUPPLIER
}

// ===== ACCOUNTING ENUMS =====
enum AccountType {
  ASSET // الأصول: صندوق، عملاء، مخزون
  LIABILITY // الالتزامات: الموردين، الضرائب
  EQUITY // حقوق الملكية
  REVENUE // الإيرادات: المبيعات
  EXPENSE // المصروفات: الشحن، الرواتب، العمولات
}

model Currency {
  id            Int      @id @default(autoincrement())
  name          String   @unique // e.g., "US Dollar", "Iraqi Dinar", "Euro"
  code          String   @unique // e.g., "USD", "IQD", "EUR"
  symbol        String // e.g., "$", "د.ع", "€"
  rate          Decimal  @default(1.0) @db.Decimal(15, 4) // Exchange rate relative to main currency
  isMain        Boolean  @default(false) // Only one currency can be main
  decimalPlaces Int      @default(2) // Number of decimal places for this currency
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  accounts               Account[]               @relation("AccountCurrency")
  salesInvoices          SalesInvoice[]          @relation("SalesInvoiceCurrency")
  purchaseInvoices       PurchaseInvoice[]       @relation("PurchaseInvoiceCurrency")
  purchaseReturnInvoices PurchaseReturnInvoice[] @relation("PurchaseReturnInvoiceCurrency")
  salesReturnInvoices    SalesReturnInvoice[]    @relation("SalesReturnInvoiceCurrency")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("currencies")
}

model Account {
  id         Int         @id @default(autoincrement())
  name       String
  type       AccountType
  code       String?
  isCash     Boolean     @default(false)
  // العملة
  currencyId Int?
  currency   Currency?   @relation("AccountCurrency", fields: [currencyId], references: [id])

  // Hierarchical structure for accounts
  parentId Int?
  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children Account[] @relation("AccountHierarchy")

  // العلاقات
  entries       TransactionLine[]
  linkedClients Client[]          @relation("ClientAccount")

  // علاقات تكوين الحسابات المحاسبية للفواتير
  debitConfigs  InvoiceAccountingConfig[] @relation("DebitAccountConfigs")
  creditConfigs InvoiceAccountingConfig[] @relation("CreditAccountConfigs")

  // علاقات تقسيمات الدفع
  invoicePayments InvoicePayment[] @relation("InvoicePaymentAccounts")

  // Default account relations for accounting settings
  defaultCustomerSettings AccountingSettings[] @relation("DefaultCustomerAccount")
  defaultSupplierSettings AccountingSettings[] @relation("DefaultSupplierAccount")

  // الحقول الأساسية
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  description String?

  // نوع المعاملة لتسهيل التصفية والاستعلام
  transactionType TransactionType @default(GENERAL)

  // ربط مع العميل
  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  // ربط مع الفواتير
  salesInvoiceId Int?
  salesInvoice   SalesInvoice? @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  purchaseInvoiceId Int?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  purchaseReturnInvoiceId Int?
  purchaseReturnInvoice   PurchaseReturnInvoice? @relation(fields: [purchaseReturnInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  salesReturnInvoiceId Int?
  salesReturnInvoice   SalesReturnInvoice? @relation(fields: [salesReturnInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // العلاقات
  entries TransactionLine[]

  // علاقات تقسيمات الدفع
  invoicePayments InvoicePayment[] @relation("InvoicePaymentTransactions")

  // الحقول الأساسية
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model TransactionLine {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  description String?
  debit       Float    @default(0)
  credit      Float    @default(0)

  // العلاقات
  accountId     Int
  account       Account     @relation(fields: [accountId], references: [id])
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ربط مع العميل (اختياري)
  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  // الحقول الأساسية
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transaction_lines")
}

// ===== INVOICE ENUMS =====
enum InvoiceStatus {
  UNPAID // غير مدفوعة
  PARTIAL // مدفوعة جزئياً
  PAID // مدفوعة بالكامل
  CANCELLED // ملغاة
  OVERDUE // متأخرة السداد
}

enum PaymentType {
  CASH // نقدي
  CREDIT // آجل (deferred payment)
  CARD // بطاقة (card payment - instant)
  BANK_TRANSFER // تحويل بنكي (bank transfer - instant)
}

enum TransactionType {
  PAYMENT // مدفوع (للموردين)
  RECEIPT // مقبوض (من العملاء)
  INVOICE // فاتورة
  GENERAL // عام
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ===== CRM MODELS =====

model Lead {
  id             String         @id @default(uuid())
  name           String
  order          Int?           @default(0)
  email          String?
  phone          String?
  description    String?
  companyName    String?
  industry       String?
  website        String?
  source         String? // Where the lead came from (website, referral, etc.)
  salesManId     String?
  salesMan       User?          @relation("LeadSalesMan", fields: [salesManId], references: [id], onDelete: SetNull)
  employeeCount  Int?
  leadActivities LeadActivity[]
  revenue        Float?
  status         LeadStatus     @default(NEW)
  isCompany      Boolean        @default(false)
  workspaceId    String
  workspace      Workspace      @relation("WorkspaceLeads", fields: [workspaceId], references: [id], onDelete: Cascade)
  stageId        String?
  stage          LeadStage?     @relation("LeadStageLeads", fields: [stageId], references: [id], onDelete: SetNull)
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model LeadActivity {
  id           String       @id @default(uuid())
  leadId       String
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType ActivityType
  meetingLink  String?
  activityDate DateTime
  assignedToId String?
  assignedTo   User?        @relation("LeadActivities", fields: [assignedToId], references: [id], onDelete: SetNull)
  description  String?
  isDone       Boolean?     @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  SMS
  VISIT
  TASK
  NOTE
  OTHER
}

model LeadStage {
  id          String    @id @default(uuid())
  name        String
  description String?
  order       Int?      @default(0)
  color       String? // For UI visualization
  workspaceId String
  workspace   Workspace @relation("WorkspaceLeadStages", fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]    @relation("LeadStageLeads")
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, order])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
  ON_HOLD
}

// Department Tables
model Department {
  id                     String                  @id @default(uuid())
  name                   String
  description            String?
  parentId               String?
  parent                 Department?             @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children               Department[]            @relation("DepartmentHierarchy")
  employees              Employee[]              @relation("EmployeeDepartment")
  purchaseReturnInvoices PurchaseReturnInvoice[] @relation("PurchaseReturnInvoiceDepartment")
  salesReturnInvoices    SalesReturnInvoice[]    @relation("SalesReturnInvoiceDepartment")

  // System Fields
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Employee Tables
model Employee {
  id            String  @id @default(uuid())
  fingerPrintId String?

  // Personal Information
  firstName          String
  lastName           String?
  leaves             Leave[]          @relation("EmployeeLeaves")
  phone              String?
  alternatePhone     String?
  dateOfBirth        DateTime?
  gender             Gender?
  workingHours       Int?             @default(8)
  daysToWorkPerMonth Int?             @default(26)
  // Address Information
  address            String?
  city               String?
  state              String?
  country            String?
  zipCode            String?
  startWorkingTime   DateTime?
  endWorkingTime     DateTime?
  // number of leaves allowed per year
  leavesAllowed      Int?             @default(21)
  salaries           Salary[]         @relation("EmployeeSalaries")
  // Employment Information
  jobId              String?
  job                Job?             @relation("EmployeeJob", fields: [jobId], references: [id], onDelete: SetNull)
  departmentId       String?
  department         Department?      @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  hireDate           DateTime?
  terminationDate    DateTime?
  employmentType     EmploymentType   @default(FULL_TIME)
  employmentStatus   EmploymentStatus @default(ACTIVE)

  // Compensation
  salary   String? // Monthly salary
  currency String? @default("IQD")

  // Work Details
  workLocation WorkLocation? @default(OFFICE) // Office location, remote, hybrid
  shiftType    ShiftType?    @default(DAY_SHIFT)

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Relationships
  managerId    String?
  manager      Employee?            @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subordinates Employee[]           @relation("EmployeeManager")
  attendances  EmployeeAttendance[] @relation("EmployeeAttendances")
  // Optional User Account (if employee has system access)
  userId       String?              @unique
  user         User?                @relation("EmployeeUser", fields: [userId], references: [id])

  // Documents relationship
  documents EmployeeDocument[] @relation("EmployeeDocuments")

  // Disciplinary Actions relationship
  disciplinaryActions DisciplinaryAction[] @relation("EmployeeDisciplinaryActions")

  // Employee Requests relationship
  requests EmployeeRequest[] @relation("EmployeeRequests")

  // Employee Exit relationship
  exit EmployeeExit? @relation("EmployeeExit")

  // Employee Benefits relationship
  benefits EmployeeBenefit[] @relation("EmployeeBenefits")

  // POS Access
  posPin       String? // 4-6 digit PIN for POS login
  hasPOSAccess Boolean        @default(false) // Permission to use POS
  posSessions  POSSession[]   @relation("EmployeePOSSessions")
  posInvoices  SalesInvoice[] @relation("POSCashierInvoices")

  // System Fields
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([fingerPrintId])
}

