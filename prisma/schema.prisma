// ===== INVOICES =====

model SalesInvoice {
  id            Int     @id @default(autoincrement())
  invoiceNumber String  @unique // رقم الفاتورة
  clientId      Int? // العميل (CUSTOMER) - Optional for walk-in customers
  client        Client? @relation(fields: [clientId], references: [id])

  // Invoice Details
  totalAmount     Decimal @db.Decimal(15, 2) // المبلغ الإجمالي
  paidAmount      Decimal @default(0.0) @db.Decimal(15, 2) // المبلغ المدفوع
  remainingAmount Decimal @db.Decimal(15, 2) // المبلغ المتبقي

  // Subtotal before discount
  subtotalBeforeDiscount Decimal? @db.Decimal(15, 2) // المجموع قبل الخصم

  // Discount
  discount     Decimal?      @default(0) @db.Decimal(15, 2) // قيمة الخصم
  discountType DiscountType? @default(FIXED) // نوع الخصم

  // Currency support
  currencyId Int? // Optional currency reference
  currency   Currency? @relation("SalesInvoiceCurrency", fields: [currencyId], references: [id])

  // Status
  status      InvoiceStatus @default(UNPAID)
  paymentType PaymentType   @default(CREDIT) // نوع الدفع: نقدي أم آجل

  // Return/Credit Note Support
  isReturn          Boolean              @default(false) // هل هذه فاتورة إرجاع؟
  originalInvoiceId Int? // معرف الفاتورة الأصلية (للإرجاعات)
  originalInvoice   SalesInvoice?        @relation("SalesInvoiceReturns", fields: [originalInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  returnInvoices    SalesInvoice[]       @relation("SalesInvoiceReturns") // فواتير الإرجاع المرتبطة بهذه الفاتورة (deprecated)
  returnInvoicesNew SalesReturnInvoice[] // فواتير الإرجاع الجديدة المرتبطة بهذه الفاتورة

  // Additional Info
  description String? // وصف الفاتورة
  notes       String? // ملاحظات
  dueDate     DateTime? // تاريخ الاستحقاق

  // User who created the invoice
  userId String?
  user   User?   @relation("CreatedSalesInvoices", fields: [userId], references: [id])

  // POS Integration
  isPOS        Boolean     @default(false) // Mark as POS transaction
  posSessionId Int? // Link to POS session
  posSession   POSSession? @relation("SessionInvoices", fields: [posSessionId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  cashierId    String? // Employee who processed (for "Served by")
  cashier      Employee?   @relation("POSCashierInvoices", fields: [cashierId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  printFormat  PrintFormat @default(RECEIPT) // Chosen print format for this invoice

  // العلاقة مع المعاملات المحاسبية
  transactions Transaction[]

  // العلاقة مع تكوين الفاتورة المحاسبي (اختياري)
  invoiceConfigId Int? // معرف تكوين الفاتورة المحاسبي
  invoiceConfig   InvoiceAccountingConfig? @relation("SalesInvoiceConfig", fields: [invoiceConfigId], references: [id])

  // Timing
  invoiceDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  // Invoice items
  items SalesInvoiceItem[]

  // Returns from warehouse transactions (deprecated - use returnInvoices instead)
  warehouseReturns WarehouseTransaction[] @relation("SalesInvoiceWarehouseReturns")

  // Payment splits - تقسيمات الدفع
  payments InvoicePayment[] @relation("SalesInvoicePayments")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([isPOS, posSessionId])
  @@index([cashierId])
  @@map("sales_invoices")
}

model PurchaseInvoice {
  id            Int    @id @default(autoincrement())
  invoiceNumber String @unique // رقم الفاتورة
  supplierId    Int // المورد (SUPPLIER)
  supplier      Client @relation(fields: [supplierId], references: [id])

  // Invoice Details
  totalAmount     Decimal @db.Decimal(15, 2) // المبلغ الإجمالي
  paidAmount      Decimal @default(0.0) @db.Decimal(15, 2) // المبلغ المدفوع
  remainingAmount Decimal @db.Decimal(15, 2) // المبلغ المتبقي

  // Subtotal before discount
  subtotalBeforeDiscount Decimal? @db.Decimal(15, 2) // المجموع قبل الخصم

  // Discount
  discount     Decimal?      @default(0) @db.Decimal(15, 2) // قيمة الخصم
  discountType DiscountType? @default(FIXED) // نوع الخصم

  // Currency support
  currencyId Int? // Optional currency reference
  currency   Currency? @relation("PurchaseInvoiceCurrency", fields: [currencyId], references: [id])

  // Status
  status      InvoiceStatus @default(UNPAID)
  paymentType PaymentType   @default(CREDIT) // نوع الدفع: نقدي أم آجل

  // Return/Debit Note Support
  isReturn          Boolean           @default(false) // هل هذه فاتورة إرجاع؟
  originalInvoiceId Int? // معرف الفاتورة الأصلية (للإرجاعات)
  originalInvoice   PurchaseInvoice?  @relation("PurchaseInvoiceReturns", fields: [originalInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  returnInvoices    PurchaseInvoice[] @relation("PurchaseInvoiceReturns") // فواتير الإرجاع المرتبطة بهذه الفاتورة (deprecated)

  // Additional Info
  description String? // وصف الفاتورة
  notes       String? // ملاحظات
  dueDate     DateTime? // تاريخ الاستحقاق

  // User who created the invoice
  userId String?
  user   User?   @relation("CreatedPurchaseInvoices", fields: [userId], references: [id])

  // العلاقة مع المعاملات المحاسبية
  transactions Transaction[]

  // العلاقة مع تكوين الفاتورة المحاسبي (اختياري)
  invoiceConfigId Int? // معرف تكوين الفاتورة المحاسبي
  invoiceConfig   InvoiceAccountingConfig? @relation("PurchaseInvoiceConfig", fields: [invoiceConfigId], references: [id])

  // Timing
  invoiceDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  // Invoice items
  items PurchaseInvoiceItem[]

  // Return invoices (new system)
  returnInvoicesNew PurchaseReturnInvoice[] // فواتير الإرجاع الجديدة المرتبطة بهذه الفاتورة

  // Returns from warehouse transactions (deprecated - use returnInvoices instead)
  warehouseReturns WarehouseTransaction[] @relation("PurchaseInvoiceWarehouseReturns")

  // Payment splits - تقسيمات الدفع
  payments InvoicePayment[] @relation("PurchaseInvoicePayments")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("purchase_invoices")
}

// ===== INVOICE ACCOUNTING CONFIGURATION =====

// جدول تكوين الحسابات المحاسبية للفواتير
model InvoiceAccountingConfig {
  id Int @id @default(autoincrement())

  // اسم التكوين - Configuration Name
  name String @default("Default Config") // اسم التكوين

  // نوع الفاتورة والدفع
  invoiceType InvoiceType // SALES أو PURCHASE
  paymentType PaymentType // CASH أو CREDIT

  // الحسابات المحاسبية
  debitAccountId  Int // الحساب المدين
  creditAccountId Int // الحساب الدائن

  // العلاقات
  debitAccount  Account @relation("DebitAccountConfigs", fields: [debitAccountId], references: [id])
  creditAccount Account @relation("CreditAccountConfigs", fields: [creditAccountId], references: [id])

  // العلاقة مع الفواتير
  salesInvoices    SalesInvoice[]    @relation("SalesInvoiceConfig")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseInvoiceConfig")

  // معلومات إضافية
  description String? // وصف التكوين
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoice_accounting_configs")
}

// نوع الفاتورة للتكوين
enum InvoiceType {
  SALES // فاتورة مبيعات
  PURCHASE // فاتورة مشتريات
}

enum DiscountType {
  FIXED // Fixed amount discount
  PERCENTAGE // Percentage discount
}

// ===== INVOICE PAYMENT SPLITS =====

enum InvoicePaymentType {
  SALES_INVOICE // فاتورة مبيعات
  PURCHASE_INVOICE // فاتورة مشتريات
}

// جدول تقسيمات الدفع للفواتير - يدعم طرق دفع متعددة في دفعة واحدة
model InvoicePayment {
  id Int @id @default(autoincrement())

  // نوع الفاتورة
  invoiceType InvoicePaymentType

  // معرف الفاتورة (يمكن أن يكون salesInvoiceId أو purchaseInvoiceId حسب invoiceType)
  salesInvoiceId    Int?
  purchaseInvoiceId Int?

  // العلاقات مع الفواتير
  salesInvoice    SalesInvoice?    @relation("SalesInvoicePayments", fields: [salesInvoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  purchaseInvoice PurchaseInvoice? @relation("PurchaseInvoicePayments", fields: [purchaseInvoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  // تفاصيل الدفع
  amount      Decimal     @db.Decimal(15, 2) // المبلغ لهذه الطريقة
  paymentType PaymentType // طريقة الدفع (نقدي، بطاقة، تحويل بنكي، آجل)

  // الحساب المحاسبي الذي استلم/دفع هذا المبلغ
  accountId Int
  account   Account @relation("InvoicePaymentAccounts", fields: [accountId], references: [id])

  // ربط مع المعاملة المحاسبية (اختياري)
  transactionId Int?
  transaction   Transaction? @relation("InvoicePaymentTransactions", fields: [transactionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ملاحظات
  notes String?

  // معلومات النظام
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
  @@index([paymentType])
  @@index([transactionId])
  @@map("invoice_payments")
}

// تحديث نموذج الحساب لإضافة العلاقات الجديدة
// (سيتم إضافة هذا إلى نموذج Account الموجود)

// ===== POS SYSTEM =====

enum PrintFormat {
  RECEIPT // 80mm thermal receipt
  A5 // A5 invoice
  A4 // A4 invoice
}

// POS Terminal Model - Support Multiple Terminals
model POS {
  id       Int     @id @default(autoincrement())
  name     String // "Cashier-1", "Main-POS", "Terminal-A"
  slug     String  @unique // "cashier-1", "main-pos", "terminal-a"
  location String? // Physical location description

  // Settings
  isActive    Boolean     @default(true)
  printFormat PrintFormat @default(RECEIPT) // Default print format

  // Current state
  isLocked Boolean   @default(false)
  lockedAt DateTime?
  lockedBy String? // Employee ID who locked it

  // Relations
  sessions POSSession[] @relation("POSSessions")

  // Audit
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("pos_terminals")
}

enum SessionStatus {
  OPEN // Active session
  CLOSED // Completed session
  SUSPENDED // Temporarily paused
}

// POS Session Model - Track Shifts/Sessions
model POSSession {
  id            Int     @id @default(autoincrement())
  sessionNumber String? // Session number

  posId Int
  pos   POS @relation("POSSessions", fields: [posId], references: [id])

  employeeId String // Cashier for this session
  employee   Employee @relation("EmployeePOSSessions", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // Session timing
  openedAt DateTime      @default(now())
  closedAt DateTime?
  status   SessionStatus @default(OPEN)

  // Cash management
  openingBalance Decimal  @db.Decimal(15, 2) // Starting cash in drawer
  closingBalance Decimal? @db.Decimal(15, 2) // Ending cash (counted)
  expectedCash   Decimal? @db.Decimal(15, 2) // Calculated from cash transactions
  cashDifference Decimal? @db.Decimal(15, 2) // Over/Short (closingBalance - expectedCash)

  // Session summary (simple counters, updated on each transaction)
  totalSales        Decimal @default(0) @db.Decimal(15, 2)
  totalTransactions Int     @default(0)

  // Note: Cash/Card/BankTransfer breakdowns are calculated via queries on invoices table, not stored

  // Relations
  invoices SalesInvoice[] @relation("SessionInvoices")

  // Notes
  openingNotes String? // Notes when opening
  closingNotes String? // Notes when closing

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([posId, status])
  @@index([employeeId])
  @@map("pos_sessions")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Admin", "Manager", "Sales Rep"
  description String? // Human-readable description
  color       String? // UI color for the role
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  userRoles       UserRole[]       @relation("RoleUsers")
  rolePermissions RolePermission[] @relation("RolePermissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation("RoleUsers", fields: [roleId], references: [id], onDelete: Cascade)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "users:create", "projects:read", "tasks:update"
  description String? // Human-readable description
  resource    String // e.g., "users", "projects", "tasks" (model name)
  action      String // e.g., "create", "read", "update", "delete"
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Many-to-many relationship with roles
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation("RolePermissions", fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([roleId, permissionId])
}

// أصناف فاتورة البيع - Sales Invoice Items
model SalesInvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int // معرف الفاتورة
  productId Int // معرف المنتج
  unitId    Int? // معرف الوحدة (اختياري)
  quantity  Decimal @db.Decimal(15, 3) // الكمية
  unitPrice Decimal @db.Decimal(15, 2) // سعر الوحدة

  // العلاقات
  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  product Product      @relation(fields: [productId], references: [id])
  unit    Unit?        @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Return items - أصناف الإرجاع المرتبطة بهذا الصنف
  returnItems WarehouseTransactionItem[] @relation("SalesInvoiceItemReturns")

  // Return invoice items - أصناف فواتير الإرجاع المرتبطة بهذا الصنف
  returnInvoiceItems SalesReturnInvoiceItem[]

  @@map("sales_invoice_items")
}

// أصناف فاتورة الشراء - Purchase Invoice Items
model PurchaseInvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int // معرف الفاتورة
  productId Int // معرف المنتج
  unitId    Int? // معرف الوحدة (اختياري)
  quantity  Decimal @db.Decimal(15, 3) // الكمية
  unitPrice Decimal @db.Decimal(15, 2) // سعر الوحدة

  // العلاقات
  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  product Product         @relation(fields: [productId], references: [id])
  unit    Unit?           @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Return items - أصناف الإرجاع المرتبطة بهذا الصنف
  returnItems WarehouseTransactionItem[] @relation("PurchaseInvoiceItemReturns")

  // Return invoice items - أصناف فواتير الإرجاع المرتبطة بهذا الصنف
  returnInvoiceItems PurchaseReturnInvoiceItem[]

  @@map("purchase_invoice_items")
}

// ===== PURCHASE RETURN INVOICES =====

// فاتورة إرجاع الشراء - Purchase Return Invoice
model PurchaseReturnInvoice {
  id                  Int             @id @default(autoincrement())
  returnInvoiceNumber String          @unique // رقم فاتورة الإرجاع
  purchaseInvoiceId   Int // معرف فاتورة الشراء الأصلية
  purchaseInvoice     PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ربط مع القسم
  departmentId String? // القسم (اختياري)
  department   Department? @relation("PurchaseReturnInvoiceDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // Invoice Details
  totalAmount Decimal @db.Decimal(15, 2) // المبلغ الإجمالي
  netAmount   Decimal @db.Decimal(15, 2) // المبلغ الصافي

  // Currency support
  currencyId Int? // العملة
  currency   Currency? @relation("PurchaseReturnInvoiceCurrency", fields: [currencyId], references: [id])

  // Status
  status InvoiceStatus @default(PAID)

  // Additional Info
  notes                  String? // ملاحظات
  returnReason           String? // سبب الإرجاع
  referenceInvoiceNumber String? // رقم الفاتورة المرجعية من الشركة الموردة

  // User who created the return invoice
  userId String?
  user   User?   @relation("CreatedPurchaseReturnInvoices", fields: [userId], references: [id])

  // العلاقة مع المعاملات المحاسبية
  transactions Transaction[]

  // Timing
  returnDate DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  // Return invoice items
  items PurchaseReturnInvoiceItem[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("purchase_return_invoices")
}

// أصناف فاتورة إرجاع الشراء - Purchase Return Invoice Items
model PurchaseReturnInvoiceItem {
  id                            Int     @id @default(autoincrement())
  returnInvoiceId               Int // معرف فاتورة الإرجاع
  originalPurchaseInvoiceItemId Int // معرف صنف فاتورة الشراء الأصلي
  productId                     Int // معرف المنتج
  unitId                        Int? // معرف الوحدة (اختياري)
  quantity                      Decimal @db.Decimal(15, 3) // الكمية المرجعة
  unitPrice                     Decimal @db.Decimal(15, 2) // سعر الوحدة
  totalPrice                    Decimal @db.Decimal(15, 2) // إجمالي السعر

  // تتبع موحد (اختياري)
  trackingId Int? // معرف التتبع
  tracking   Tracking? @relation("PurchaseReturnInvoiceItemTracking", fields: [trackingId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ملاحظات
  notes String? // ملاحظات خاصة بالصنف

  // العلاقات
  returnInvoice               PurchaseReturnInvoice @relation(fields: [returnInvoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  originalPurchaseInvoiceItem PurchaseInvoiceItem   @relation(fields: [originalPurchaseInvoiceItemId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product                     Product               @relation("PurchaseReturnInvoiceItemProduct", fields: [productId], references: [id])
  unit                        Unit?                 @relation("PurchaseReturnInvoiceItemUnit", fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchase_return_invoice_items")
}

// ===== SALES RETURN INVOICES =====

// فاتورة إرجاع البيع - Sales Return Invoice
model SalesReturnInvoice {
  id                  Int          @id @default(autoincrement())
  returnInvoiceNumber String       @unique // رقم فاتورة الإرجاع
  salesInvoiceId      Int // معرف فاتورة البيع الأصلية
  salesInvoice        SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ربط مع القسم
  departmentId String? // القسم (اختياري)
  department   Department? @relation("SalesReturnInvoiceDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // Invoice Details
  totalAmount Decimal @db.Decimal(15, 2) // المبلغ الإجمالي
  netAmount   Decimal @db.Decimal(15, 2) // المبلغ الصافي

  // Currency support
  currencyId Int? // العملة
  currency   Currency? @relation("SalesReturnInvoiceCurrency", fields: [currencyId], references: [id])

  // Status
  status InvoiceStatus @default(PAID)

  // Additional Info
  notes                  String? // ملاحظات
  returnReason           String? // سبب الإرجاع
  referenceInvoiceNumber String? // رقم الفاتورة المرجعية من العميل

  // User who created the return invoice
  userId String?
  user   User?   @relation("CreatedSalesReturnInvoices", fields: [userId], references: [id])

  // العلاقة مع المعاملات المحاسبية
  transactions Transaction[]

  // Timing
  returnDate DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  // Return invoice items
  items SalesReturnInvoiceItem[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("sales_return_invoices")
}

// أصناف فاتورة إرجاع البيع - Sales Return Invoice Items
model SalesReturnInvoiceItem {
  id                         Int     @id @default(autoincrement())
  returnInvoiceId            Int // معرف فاتورة الإرجاع
  originalSalesInvoiceItemId Int // معرف صنف فاتورة البيع الأصلي
  productId                  Int // معرف المنتج
  unitId                     Int? // معرف الوحدة (اختياري)
  quantity                   Decimal @db.Decimal(15, 3) // الكمية المرجعة
  unitPrice                  Decimal @db.Decimal(15, 2) // سعر الوحدة
  totalPrice                 Decimal @db.Decimal(15, 2) // إجمالي السعر

  // تتبع موحد (اختياري)
  trackingId Int? // معرف التتبع
  tracking   Tracking? @relation("SalesReturnInvoiceItemTracking", fields: [trackingId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // ملاحظات
  notes String? // ملاحظات خاصة بالصنف

  // العلاقات
  returnInvoice            SalesReturnInvoice @relation(fields: [returnInvoiceId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  originalSalesInvoiceItem SalesInvoiceItem   @relation(fields: [originalSalesInvoiceItemId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product                  Product            @relation("SalesReturnInvoiceItemProduct", fields: [productId], references: [id])
  unit                     Unit?              @relation("SalesReturnInvoiceItemUnit", fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sales_return_invoice_items")
}

// ===============================
// WAREHOUSE MANAGEMENT SYSTEM
// نظام إدارة المخازن والمخزون - متقدم ومرن
// ===============================

// ===============================
// ENHANCED UNIT MEASUREMENT SYSTEM
// نظام الوحدات المتقدم والمبسط
// ===============================

// 1. فئات الوحدات - Unit Categories (الطول، الوزن، الحجم، إلخ)
model UnitCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique // اسم فئة الوحدة (طول، وزن، حجم، إلخ)
  description String? // وصف فئة الوحدة

  // إعدادات
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  units Unit[] // الوحدات التابعة لهذه الفئة

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("unit_categories")
}

// 2. الوحدات المحسنة - Enhanced Units
model Unit {
  id          Int          @id @default(autoincrement())
  name        String // اسم الوحدة (متر، سنتيمتر، كيلومتر، إلخ)
  symbol      String? // رمز الوحدة (m، cm، km، إلخ)
  description String? // وصف الوحدة
  categoryId  Int // معرف فئة الوحدة
  category    UnitCategory @relation(fields: [categoryId], references: [id])

  // نوع الوحدة ونسبة التحويل
  type  UnitType @default(MAIN) // MAIN (الأساسية)، SMALLER (أصغر)، BIGGER (أكبر)
  ratio Decimal  @default(1.0) @db.Decimal(15, 6) // نسبة التحويل

  // إعدادات
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات مع المنتجات
  productsAsSalesUnit    Product[] @relation("ProductSalesUnit") // المنتجات التي تستخدم هذه الوحدة للبيع
  productsAsPurchaseUnit Product[] @relation("ProductPurchaseUnit") // المنتجات التي تستخدم هذه الوحدة للشراء

  // العلاقات مع فواتير البيع والشراء
  salesInvoiceItems          SalesInvoiceItem[] // أصناف فواتير البيع التي تستخدم هذه الوحدة
  purchaseInvoiceItems       PurchaseInvoiceItem[] // أصناف فواتير الشراء التي تستخدم هذه الوحدة
  purchaseReturnInvoiceItems PurchaseReturnInvoiceItem[] @relation("PurchaseReturnInvoiceItemUnit") // أصناف فواتير إرجاع الشراء التي تستخدم هذه الوحدة
  salesReturnInvoiceItems    SalesReturnInvoiceItem[]    @relation("SalesReturnInvoiceItemUnit") // أصناف فواتير إرجاع البيع التي تستخدم هذه الوحدة

  // العلاقات مع التتبع
  storageTrackings Tracking[] @relation("StorageUnit") // التتبع الذي يستخدم هذه الوحدة للتخزين

  // العلاقات مع حركات المخزون
  warehouseTransactionItems WarehouseTransactionItem[] // أصناف حركات المخزون التي تستخدم هذه الوحدة

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name]) // منع تكرار الاسم في نفس الفئة
  @@map("units")
}

// 2. المنتجات - Products (مع وحدتين منفصلتين للبيع والشراء)
model Product {
  id          Int     @id @default(autoincrement())
  name        String // اسم المنتج
  barcode     String  @unique // الباركود
  description String? // وصف المنتج (اختياري)

  // نوع المنتج - Product Type
  type ProductType @default(PRODUCT) // منتج حقيقي أو خدمة

  // وحدات القياس
  salesUnitId    Int? // وحدة البيع (مثل: علبة)
  purchaseUnitId Int? // وحدة الشراء (مثل: كرتون)
  salesUnit      Unit? @relation("ProductSalesUnit", fields: [salesUnitId], references: [id])
  purchaseUnit   Unit? @relation("ProductPurchaseUnit", fields: [purchaseUnitId], references: [id])

  // الأسعار
  purchasePrice Decimal? @db.Decimal(15, 2) // سعر الشراء (بالوحدة الشرائية)
  salePrice     Decimal? @db.Decimal(15, 2) // سعر البيع (بالوحدة البيعية)

  // خصائص المنتج
  minStockAlert Decimal? @db.Decimal(15, 3) // حد التنبيه للمخزون
  imageUrl      String? // رابط صورة المنتج

  // إعدادات
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  stocks                     Stock[]
  warehouseTransactionItems  WarehouseTransactionItem[]
  salesInvoiceItems          SalesInvoiceItem[]
  purchaseInvoiceItems       PurchaseInvoiceItem[]
  purchaseReturnInvoiceItems PurchaseReturnInvoiceItem[] @relation("PurchaseReturnInvoiceItemProduct")
  salesReturnInvoiceItems    SalesReturnInvoiceItem[]    @relation("SalesReturnInvoiceItemProduct")
  categories                 ProductCategoryRelation[]
  saleItems                  SaleItem[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("products")
}

// 2.1. فئات المنتجات - Product Categories
model ProductCategory {
  id          Int                       @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean                   @default(true)
  isDeleted   Boolean                   @default(false)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  products    ProductCategoryRelation[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("product_categories")
}

// 2.2. علاقة المنتجات بالفئات - Product Category Relation (Many-to-Many)
model ProductCategoryRelation {
  id         Int             @id @default(autoincrement())
  productId  Int
  categoryId Int
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([productId, categoryId])
  @@map("product_category_relations")
}

// 3. المخازن - Warehouses (مع دعم الهيكل المتداخل 🪜)
model Warehouse {
  id          Int     @id @default(autoincrement())
  name        String // اسم المخزن
  parentId    Int? // معرف المخزن الأب (للهيكل المتداخل)
  location    String? // الموقع (اختياري)
  description String? // وصف المخزن (اختياري)

  // العلاقات الهرمية
  parent   Warehouse?  @relation("WarehouseHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children Warehouse[] @relation("WarehouseHierarchy")

  // إعدادات
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  stocks           Stock[]
  transactionsFrom WarehouseTransaction[] @relation("FromWarehouse")
  transactionsTo   WarehouseTransaction[] @relation("ToWarehouse")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("warehouses")
}

// 5. مخزون المنتجات - Stock (مرجع فقط بدون quantity)
model Stock {
  id               Int      @id @default(autoincrement())
  productId        Int // معرف المنتج
  warehouseId      Int // معرف المخزن
  reorderLevel     Decimal? @db.Decimal(15, 3) // مستوى إعادة الطلب (اختياري)
  quantityReserved Decimal  @default(0) @db.Decimal(15, 3) // Reserved from confirmed sales orders

  // العلاقات
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // تتبع الدفعات والأرقام التسلسلية والمنتجات بدون تتبع
  trackings Tracking[]

  // تواريخ
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, warehouseId]) // مخزون واحد لكل منتج في كل مخزن
  @@map("stocks")
}

// 5.1. تتبع موحد - Unified Tracking (لجميع أنواع التتبع)
model Tracking {
  id      Int @id @default(autoincrement())
  stockId Int // معرف المخزون

  // نوع التتبع
  trackingType ProductTrackingType // NONE, LOT, SERIAL

  // معرفات التتبع (حسب النوع)
  lotNumber    String? // رقم الدفعة (للمنتجات التي تتبع بالدفعات)
  serialNumber String? // الرقم التسلسلي (للمنتجات التي تتبع بالأرقام التسلسلية)
  batchName    String? // اسم الدفعة (للمنتجات العادية التي لها دفعات)

  // الوحدة والكمية
  storageUnitId Int? // وحدة التخزين (كارتون، قطعة، إلخ)
  storageUnit   Unit?   @relation("StorageUnit", fields: [storageUnitId], references: [id])
  quantity      Decimal @db.Decimal(15, 3) // كمية هذه الدفعة/الرقم التسلسلي بالوحدة المحددة

  // تواريخ مهمة (للدفعات)
  productionDate DateTime? // تاريخ الإنتاج
  expiryDate     DateTime? // تاريخ انتهاء الصلاحية

  // معلومات إضافية
  supplierName String? // اسم المورد (اختياري)
  notes        String? // ملاحظات (اختياري)

  // إعدادات
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  // معاملات هذا التتبع
  transactionItems           WarehouseTransactionItem[]
  purchaseReturnInvoiceItems PurchaseReturnInvoiceItem[] @relation("PurchaseReturnInvoiceItemTracking")
  salesReturnInvoiceItems    SalesReturnInvoiceItem[]    @relation("SalesReturnInvoiceItemTracking")

  @@unique([stockId, lotNumber, serialNumber, batchName]) // منع التكرار
  @@map("trackings")
}

// 6. المعاملات/الحركات - Warehouse Transactions (دعم منتجات متعددة)
model WarehouseTransaction {
  id              Int                      @id @default(autoincrement())
  type            WarehouseTransactionType // نوع المعاملة
  fromWarehouseId Int? // المخزن المصدر (nullable)
  toWarehouseId   Int? // المخزن الهدف (nullable)

  // إجمالي السعر للمعاملة الكاملة (مجموع كل الأصناف)
  totalPrice Decimal? @db.Decimal(15, 2) // إجمالي السعر

  // معلومات إضافية
  date            DateTime @default(now()) // تاريخ ووقت المعاملة
  note            String? // ملاحظة (اختيارية)
  partyName       String? // اسم الطرف (عميل/مورد) (اختياري)
  referenceNumber String? // رقم مرجعي (رقم فاتورة مثلاً)
  userId          String? // المستخدم الذي قام بالمعاملة

  // ربط بالفواتير (للإرجاعات)
  salesInvoiceId    Int? // معرف فاتورة البيع المرتبطة بالإرجاع
  purchaseInvoiceId Int? // معرف فاتورة الشراء المرتبطة بالإرجاع

  // العلاقات
  fromWarehouse Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  toWarehouse   Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user          User?      @relation("WarehouseTransactions", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // علاقات الفواتير (للإرجاعات)
  salesInvoice    SalesInvoice?    @relation("SalesInvoiceWarehouseReturns", fields: [salesInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  purchaseInvoice PurchaseInvoice? @relation("PurchaseInvoiceWarehouseReturns", fields: [purchaseInvoiceId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // أصناف المعاملة (دعم منتجات متعددة مع تتبع)
  items WarehouseTransactionItem[]

  // تواريخ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("warehouse_transactions")
}

// 6.1. أصناف معاملات المخزون - Warehouse Transaction Items (مع تتبع موحد)
model WarehouseTransactionItem {
  id            Int      @id @default(autoincrement())
  transactionId Int // معرف المعاملة
  productId     Int // معرف المنتج
  quantity      Decimal  @db.Decimal(15, 3) // الكمية
  unitPrice     Decimal? @db.Decimal(15, 2) // سعر الوحدة (شراء أو بيع)
  totalPrice    Decimal? @db.Decimal(15, 2) // إجمالي السعر للصنف

  // تتبع موحد (اختياري)
  trackingId Int? // معرف التتبع (إذا كان المنتج له تتبع)
  tracking   Tracking? @relation(fields: [trackingId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // الوحدة المستخدمة في الحركة (اختياري)
  unitId Int? // معرف الوحدة المستخدمة في الحركة
  unit   Unit? @relation(fields: [unitId], references: [id])

  // ملاحظة خاصة بالصنف (اختيارية)
  itemNote String?

  // ربط بأصناف الفواتير الأصلية (للإرجاعات)
  originalSalesInvoiceItemId    Int? // معرف صنف فاتورة البيع الأصلي
  originalPurchaseInvoiceItemId Int? // معرف صنف فاتورة الشراء الأصلي

  // العلاقات
  transaction WarehouseTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  product     Product              @relation(fields: [productId], references: [id])

  // علاقات أصناف الفواتير الأصلية (للإرجاعات)
  originalSalesInvoiceItem    SalesInvoiceItem?    @relation("SalesInvoiceItemReturns", fields: [originalSalesInvoiceItemId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  originalPurchaseInvoiceItem PurchaseInvoiceItem? @relation("PurchaseInvoiceItemReturns", fields: [originalPurchaseInvoiceItemId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warehouse_transaction_items")
}

// أنواع معاملات المخزون (مبسط)
enum WarehouseTransactionType {
  PURCHASE // شراء - إدخال بضاعة جديدة من مورد
  SALE // بيع - بيع في الصيدلية للزبائن
  DISPENSE // صرف - صرف للمرضى في العيادة
  TRANSFER // تحويل - نقل بين المخازن
  ADJUST // تعديل - تصحيح المخزون (زيادة أو نقص)
  DAMAGE // إتلاف - إتلاف المخزون التالف أو منتهي الصلاحية
  ADD // إضافة - إضافة مخزون جديد مباشرة (بدون مورد)
  RETURN // إرجاع - إرجاع أصناف من فاتورة بيع أو شراء
}

// أنواع الوحدات
enum UnitType {
  MAIN // الوحدة الأساسية (مثل المتر، ratio = 1)
  SMALLER // وحدة أصغر (مثل السنتيمتر، ratio = 100)
  BIGGER // وحدة أكبر (مثل الكيلومتر، ratio = 1000)
}

// أنواع تتبع المنتجات - Product Tracking Types (مثل Odoo)
enum ProductTrackingType {
  NONE // لا يوجد تتبع - No tracking
  LOT // تتبع بالدفعات - Track by lots/batches
  SERIAL // تتبع بالأرقام التسلسلية - Track by serial numbers
}

// أنواع المنتجات - Product Types
enum ProductType {
  PRODUCT // منتج حقيقي - Physical product (يمكن تخزينه في المخازن)
  SERVICE // خدمة - Service (لا يمكن تخزينها ولا تتبعها)
}

// ===== INVOICE TEMPLATES =====

enum InvoiceTemplateType {
  INVOICE // فاتورة
  RECEIPT // إيصال
}

model InvoiceTemplate {
  id                Int                 @id @default(autoincrement())
  type              InvoiceTemplateType @unique // Only one template per type
  headerCompanyName String // Company name for header
  headerAddress     String? // Company address for header
  headerLogoUrl     String? // Logo URL for header
  footerText        String? // Footer text
  isActive          Boolean             @default(true)
  isDeleted         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoice_templates")
}

// ===== SALES MODULE (Odoo-Style) =====

enum SaleType {
  QUOTATION // Full workflow (Quotation → Sales Order → Delivery → Invoice)
  DIRECT // One-step sale (immediate stock deduction)
}

enum SaleStatus {
  DRAFT // Quotation created, not sent
  SENT // Quotation sent to customer
  CONFIRMED // Quotation confirmed → stock reserved
  COMPLETED // Sale completed (direct or after delivery)
  CANCELLED // Cancelled
  PARTIAL // Partial delivery done
}

enum SalePaymentStatus {
  PENDING
  PAID
  PARTIAL_PAYMENT
  REFUNDED
}

enum SaleDeliveryStatus {
  DRAFT
  READY
  DONE
  CANCELLED
}

model Sale {
  id       Int        @id @default(autoincrement())
  name     String     @unique // e.g., SO-0001 or DS-0001
  saleType SaleType   @default(QUOTATION)
  status   SaleStatus @default(DRAFT)

  // Customer (optional for walk-in direct sales)
  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  // Warehouse for stock operations
  warehouseId Int

  // Dates
  dateOrder     DateTime  @default(now())
  dateConfirmed DateTime?
  dateCompleted DateTime?

  // For QUOTATION type
  validityDate DateTime?

  // For DIRECT type - payment info
  paymentMethod String? // cash, card, transfer
  paymentStatus SalePaymentStatus @default(PENDING)

  // Amounts
  amountUntaxed Decimal      @default(0) @db.Decimal(15, 2)
  taxRate       Decimal      @default(0) @db.Decimal(5, 2) // Tax percentage
  amountTax     Decimal      @default(0) @db.Decimal(15, 2)
  amountTotal   Decimal      @default(0) @db.Decimal(15, 2)
  discount      Decimal      @default(0) @db.Decimal(15, 2) // Total discount
  discountType  DiscountType @default(FIXED)

  notes String?

  // Creator
  userId String?
  user   User?   @relation("SaleCreator", fields: [userId], references: [id])

  // Relations
  items      SaleItem[]
  deliveries SaleDelivery[]

  // Link to warehouse transactions for stock moves
  warehouseTransactionId Int? // Main transaction created for this sale

  // System fields
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([saleType])
  @@index([status])
  @@index([clientId])
  @@index([dateOrder])
  @@map("sales")
}

model SaleItem {
  id                Int          @id @default(autoincrement())
  saleId            Int
  sale              Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId         Int
  product           Product      @relation(fields: [productId], references: [id])
  quantity          Decimal      @db.Decimal(15, 3)
  quantityDelivered Decimal      @default(0) @db.Decimal(15, 3)
  unitPrice         Decimal      @db.Decimal(15, 2)
  discount          Decimal      @default(0) @db.Decimal(15, 2) // Per-item discount
  discountType      DiscountType @default(FIXED)
  subtotal          Decimal      @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SaleDelivery {
  id     Int                @id @default(autoincrement())
  name   String             @unique // e.g., DEL-0001
  saleId Int
  sale   Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  date   DateTime           @default(now())
  status SaleDeliveryStatus @default(DRAFT)
  notes  String?

  // Link to the warehouse transaction created when delivery is validated
  warehouseTransactionId Int?

  // System fields
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([status])
  @@map("sale_deliveries")
}

enum UserRoleType {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

